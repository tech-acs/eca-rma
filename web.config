<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <httpProtocol>
      <customHeaders>
        <!-- After this is active, remove CSP <meta http-equiv="Content-Security-Policy"...> from index.html to avoid policy drift. -->
        <!-- Clean previous values if inherited -->
        <remove name="Content-Security-Policy" />
        <remove name="X-Frame-Options" />
        <remove name="X-Content-Type-Options" />
        <remove name="Referrer-Policy" />
        <remove name="Permissions-Policy" />
        <remove name="Strict-Transport-Security" />
        <remove name="Cross-Origin-Opener-Policy" />
        <remove name="Cross-Origin-Embedder-Policy" />
        <remove name="Cross-Origin-Resource-Policy" />
        <remove name="Cache-Control" />
        <remove name="Pragma" />
        <remove name="Expires" />

        <!-- Security headers -->
        <add name="Content-Security-Policy"
             value="default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: https:; font-src 'self'; connect-src 'self' https:; object-src 'none'; frame-src 'none'; child-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; upgrade-insecure-requests" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="Permissions-Policy" value="geolocation=(), microphone=(), camera=(), fullscreen=(self)" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
        <add name="Cross-Origin-Opener-Policy" value="same-origin" />
        <add name="Cross-Origin-Embedder-Policy" value="require-corp" />
        <add name="Cross-Origin-Resource-Policy" value="same-origin" />

        <!-- Cache control (strict) -->
        <add name="Cache-Control" value="no-store, no-cache, must-revalidate, max-age=0" />
        <add name="Pragma" value="no-cache" />
        <add name="Expires" value="0" />
      </customHeaders>
    </httpProtocol>

    <!-- Also disable IIS static cache -->
    <staticContent>
      <clientCache cacheControlMode="DisableCache" />
    </staticContent>
  </system.webServer>
</configuration>
